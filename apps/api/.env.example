# Local dev (no Docker): SQLite — works immediately
DATABASE_URL=sqlite+aiosqlite:///./osaja_welfare.db

# Production / Docker: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/osaja_welfare
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production-use-long-random-string
DEBUG=true

# Supabase (production auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# Set false to use Supabase Auth when credentials are configured
USE_LOCAL_AUTH=true
