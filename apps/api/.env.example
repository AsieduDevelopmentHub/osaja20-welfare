# Local dev (no Docker): SQLite
# DATABASE_URL=sqlite+aiosqlite:///./osaja_welfare.db

# Supabase PostgreSQL — use session pooler port 5432 (6543 is auto-upgraded at runtime)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
REDIS_URL=redis://localhost:6379/0
JOB_WORKER_ENABLED=true

# Email digest (SMTP) — optional
EMAIL_ENABLED=false
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@osaja.com
# SMTP_USE_TLS=true
JWT_SECRET=change-me-in-production-use-long-random-string
DEBUG=true
# Set false in production — requires strong JWT_SECRET (32+ chars) and PostgreSQL
REGISTRATION_AUTO_APPROVE=true
RATE_LIMIT_AUTH_PER_MINUTE=10
# Disable Cloudflare tunnel CORS in production
ALLOW_TUNNEL_CORS=true

# Supabase (production auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# Set false to use Supabase Auth when credentials above are filled in
USE_LOCAL_AUTH=false

# Member portal URL — used as password-reset redirect fallback (must match Supabase redirect URLs)
# MEMBER_PORTAL_URL=http://localhost:3000

# Comma-separated browser origins allowed to call the API directly (optional)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Any *.trycloudflare.com host is allowed via regex by default

# Web Push (VAPID) — npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT_EMAIL=admin@osaja.com
