# Copy this file to `.env.local` in the same folder and edit values.
# Restart `pnpm dev:member` after changes.
#
# --- PRODUCTION (Vercel) — required ---
# API_PROXY_TARGET=https://your-api.onrender.com
# NEXT_PUBLIC_SITE_URL=https://your-member.vercel.app

# --- API ---
# Leave empty for auto-detect:
#   localhost  → http://localhost:8000/api/v1
#   tunnel URL → same-origin /api/v1 (proxied by next.config.ts)
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Next.js → FastAPI proxy target (server-side only, not exposed to browser)
# API_PROXY_TARGET=http://127.0.0.1:8000

# --- App ---
# Public URL for Open Graph / share previews (production: https://members.your-domain.com)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase password reset ---
# In Supabase Dashboard → Authentication → URL Configuration, add Redirect URLs:
#   http://localhost:3000/reset-password
#   https://YOUR-TUNNEL.trycloudflare.com/reset-password   (if using cloudflare tunnel)
#   https://members.your-domain.com/reset-password         (production)
# Site URL can stay http://localhost:3000 — recovery links must use /reset-password exactly.
NEXT_PUBLIC_APP_NAME=OSAJA'20 Welfare
NEXT_PUBLIC_CURRENCY=GHS
NEXT_PUBLIC_MONTHLY_DUES_AMOUNT=30

# --- Mobile Money ---
NEXT_PUBLIC_MOMO_ENABLED=true
NEXT_PUBLIC_MOMO_LABEL=Mobile Money (MTN)
NEXT_PUBLIC_MOMO_DETAIL=Send your monthly dues to the welfare MoMo number below. Use your Member ID as the reference.
NEXT_PUBLIC_MOMO_NUMBER=0241234567
NEXT_PUBLIC_MOMO_ACCOUNT_NAME=OSAJA'20 Welfare Fund

# --- Bank transfer ---
NEXT_PUBLIC_BANK_ENABLED=true
NEXT_PUBLIC_BANK_LABEL=Bank transfer
NEXT_PUBLIC_BANK_DETAIL=Transfer to the welfare account. Share your receipt with the treasurer on WhatsApp.
NEXT_PUBLIC_BANK_NAME=GCB Bank
NEXT_PUBLIC_BANK_ACCOUNT_NAME=OSAJA'20 Welfare Fund
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=1234567890123

# --- Payment (manual fallback only — online dues use Paystack via API keys) ---
NEXT_PUBLIC_PAYMENT_TITLE=How to pay your dues
NEXT_PUBLIC_PAYMENT_NOTE=If online payment is unavailable, pay via MoMo or bank and contact the treasurer.

# --- Contact (floating help button on portal pages) ---
# Match WHATSAPP_NUMBER in apps/api/.env — use / between multiple numbers
NEXT_PUBLIC_WHATSAPP_NUMBER=233531273626/233532918613
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hello, I need assistance with OSAJA'20 Welfare.
NEXT_PUBLIC_CONTACT_EMAIL=admin@osaja.com
# NEXT_PUBLIC_CONTACT_PHONE=0241234567
NEXT_PUBLIC_CONTACT_TITLE=Contact us
NEXT_PUBLIC_CONTACT_NOTE=Reach the welfare executives for dues, claims, or account help.
